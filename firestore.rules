rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isEmployee() {
      return isAuthenticated() && getUserRole() == 'employee';
    }

    function isCompany() {
      return isAuthenticated() && getUserRole() == 'company';
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    // ==================== USERS COLLECTION ====================
    match /users/{userId} {
      // Authenticated users can read:
      // - their own profile
      // - any company profile (needed for job details / company previews)
      // - admins can read all
      allow read: if isAuthenticated() && (
        isUser(userId) ||
        isAdmin() ||
        resource.data.role == 'company'
      );

      // Users can update their own profile
      allow update: if isAuthenticated() && isUser(userId);

      // Users can create their own profile (during signup)
      allow create: if isAuthenticated() && isUser(userId);

      // Allow listing users (used for public company/employee browsing)
      // Actual visibility is still controlled by the per-document read rule above.
      allow list: if true;

      // Prevent delete
      allow delete: if false;
    }

    // ==================== JOBS COLLECTION ====================
    match /jobs/{jobId} {
      // Anyone can read jobs (public listings / previews)
      allow read: if true;

      // Companies can create new jobs
      allow create: if isAuthenticated() && isCompany();

      // Companies can update their own jobs
      allow update: if isAuthenticated() && isCompany() &&
                       resource.data.companyId == request.auth.uid;

      // Companies can delete their own jobs
      allow delete: if isAuthenticated() && isCompany() &&
                       resource.data.companyId == request.auth.uid;

      // Admin can update all jobs
      allow update: if isAdmin();
    }

    // ==================== APPLICATIONS COLLECTION ====================
    match /applications/{applicationId} {
      // Employees can read their own applications
      allow read: if isAuthenticated() &&
                     (isUser(resource.data.employeeId) || isAdmin());

      // Companies can read applications for their jobs
      allow read: if isAuthenticated() && isCompany() && (
                     // Preferred: application stores companyId
                     (resource.data.companyId is string && resource.data.companyId == request.auth.uid) ||
                     // Backward-compat: derive ownership from the job document
                     (resource.data.jobId is string &&
                      get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.companyId == request.auth.uid)
                  );

      // Employees can create applications
      allow create: if isAuthenticated() && isEmployee() &&
                       request.resource.data.employeeId == request.auth.uid;

      // Employees can update their own applications (e.g., conversationId)
      allow update: if isAuthenticated() && isEmployee() &&
                       resource.data.employeeId == request.auth.uid;

      // Companies can update application status
      allow update: if isAuthenticated() && isCompany() && (
                      (resource.data.companyId is string && resource.data.companyId == request.auth.uid) ||
                      (resource.data.jobId is string &&
                       get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.companyId == request.auth.uid)
                    ) &&
                    request.resource.data.status is string;

      // Prevent delete
      allow delete: if false;

      // Admin can read/update all applications
      allow read, update: if isAuthenticated() && isAdmin();
    }

    // ==================== SAVED JOBS COLLECTION ====================
    match /savedJobs/{savedJobId} {
      // Employees can read their own saved jobs
      allow read: if isAuthenticated() &&
                     (isUser(resource.data.employeeId) || isAdmin());

      // Employees can create saved jobs
      allow create: if isAuthenticated() && isEmployee() &&
                       request.resource.data.employeeId == request.auth.uid;

      // Employees can delete their own saved jobs
      allow delete: if isAuthenticated() && isEmployee() &&
                       isUser(resource.data.employeeId);

      // Prevent updates
      allow update: if false;

      // Admin can read all saved jobs
      allow read: if isAdmin();
    }

    // ==================== CONVERSATIONS COLLECTION ====================
    match /conversations/{conversationId} {
      // Users can read conversations they are part of
      allow read: if isAuthenticated() &&
                     (request.auth.uid in resource.data.participants || isAdmin());

      // Users can create conversations
      allow create: if isAuthenticated() &&
                       request.auth.uid in request.resource.data.participants;

      // Users can update conversations they are part of
      allow update: if isAuthenticated() &&
                       (request.auth.uid in resource.data.participants || isAdmin());

      // Allow participants (or admin) to delete a conversation
      allow delete: if isAuthenticated() &&
                      (request.auth.uid in resource.data.participants || isAdmin());

      // ==================== MESSAGES SUBCOLLECTION ====================
      match /messages/{messageId} {
        // Users can read messages in their conversations
        allow read: if isAuthenticated() &&
                       (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || isAdmin());

        // Users can create messages in conversations they're part of
        allow create: if isAuthenticated() &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Users can update their own messages
        allow update: if isAuthenticated() &&
                         isUser(resource.data.senderId);

        // Allow deleting messages if you're in the conversation (or admin)
        allow delete: if isAuthenticated() &&
                        (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || isAdmin());
      }
    }

    // ==================== NOTIFICATIONS COLLECTION ====================
    match /notifications/{notificationId} {
      // App uses employeeId (employee notifications) and companyId (company notifications)
      allow read: if isAuthenticated() && (
                    (resource.data.employeeId is string && resource.data.employeeId == request.auth.uid) ||
                    (resource.data.companyId is string && resource.data.companyId == request.auth.uid) ||
                    isAdmin()
                  );

      // Allow creating notifications only for self (or admin).
      // In production you'd typically create via Cloud Functions using admin SDK.
      allow create: if isAuthenticated() && (
                      (request.resource.data.employeeId is string && request.resource.data.employeeId == request.auth.uid) ||
                      (request.resource.data.companyId is string && request.resource.data.companyId == request.auth.uid) ||
                      isAdmin()
                    );

      // Allow owners to update/delete their notifications (e.g., mark read)
      allow update, delete: if isAuthenticated() && (
                              (resource.data.employeeId is string && resource.data.employeeId == request.auth.uid) ||
                              (resource.data.companyId is string && resource.data.companyId == request.auth.uid) ||
                              isAdmin()
                            );
    }

    // ==================== CONTACTS COLLECTION ====================
    match /contacts/{contactId} {
      // Companies can read contacts (for their inquiries)
      allow read: if isAuthenticated() &&
                     (isCompany() || isAdmin());

      // Anyone can create a contact message
      allow create: if true;

      // Companies and admins can update contacts
      allow update: if isAuthenticated() &&
                       (isCompany() || isAdmin());

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ==================== DEFAULT DENY ====================
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
